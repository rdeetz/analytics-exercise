# Copy this file to `.env` and fill in the values before running `docker compose up --build`.

# Your Anthropic API key — required for Part 3 (the NL-to-SQL endpoint).
# Get one at https://console.anthropic.com/. Parts 1 and 2 do not need this.
ANTHROPIC_API_KEY=

# Postgres connection. These are wired through to the db, api, and dbt services.
# The defaults below are fine for local development.
POSTGRES_USER=blueprint
POSTGRES_PASSWORD=blueprint
POSTGRES_DB=blueprint
POSTGRES_HOST=db
POSTGRES_PORT=5432
